<% content_for :title, "Admin Console" %>

<main class="admin-screen">
  <section class="admin-card wide">
    <header class="admin-header">
      <div>
        <p class="kicker">OPERATOR CONSOLE</p>
        <h1><%= @settings.site_name %></h1>
      </div>
      <nav class="admin-actions" aria-label="Admin actions">
        <%= link_to "View Menu", root_path, class: "button ghost" %>
        <%= link_to "Edit Page", edit_admin_settings_path, class: "button" %>
        <%= link_to "Add Game", new_admin_game_path, class: "button primary" %>
        <%= button_to "Logout", admin_logout_path, method: :delete, class: "button danger" %>
      </nav>
    </header>

    <%= render "shared/flash" %>

    <div class="console-grid">
      <article class="console-panel">
        <h2>Boot Screen</h2>
        <dl class="settings-list">
          <div><dt>Headline</dt><dd><%= @settings.headline %></dd></div>
          <div><dt>Subheadline</dt><dd><%= @settings.subheadline %></dd></div>
          <div><dt>Footer</dt><dd><%= @settings.footer_note %></dd></div>
        </dl>
      </article>

      <article class="console-panel">
        <h2>Palette</h2>
        <div class="swatches">
          <span style="--swatch: <%= @settings.accent_color %>"><%= @settings.accent_color %></span>
          <span style="--swatch: <%= @settings.secondary_color %>"><%= @settings.secondary_color %></span>
          <span style="--swatch: <%= @settings.background_color %>"><%= @settings.background_color %></span>
        </div>
      </article>
    </div>

    <section class="console-panel">
      <div class="section-heading">
        <h2>Games</h2>
        <%= link_to "Manage all", admin_games_path, class: "terminal-link" %>
      </div>

      <div class="admin-table" role="table" aria-label="Games">
        <div class="table-row table-head" role="row">
          <span>Order</span>
          <span>Title</span>
          <span>URL</span>
          <span>Status</span>
          <span>Actions</span>
        </div>
        <% @games.each do |game| %>
          <div class="table-row" role="row">
            <span><%= game.position %></span>
            <span><strong><%= game.title %></strong><small><%= game.cabinet_code %> / <%= game.genre %></small></span>
            <span><%= game.url %></span>
            <span><%= game.published? ? "Published" : "Hidden" %></span>
            <span class="row-actions">
              <%= link_to "Edit", edit_admin_game_path(game), class: "terminal-link" %>
              <%= button_to "Delete", admin_game_path(game), method: :delete, class: "link-button", form: { data: { turbo_confirm: "Delete #{game.title}?" } } %>
            </span>
          </div>
        <% end %>
      </div>
    </section>
  </section>
</main>
